digraph "Camera"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="Camera",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Camera node used to view the 3D scene."];
  Node2 -> Node1 [id="edge1_Node000001_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="Node",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_node.html",tooltip="Base node of the scene graph, handling transformations and hierarchy."];
  Node3 -> Node2 [id="edge2_Node000002_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="Object",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_object.html",tooltip="Base abstract class for all scene objects."];
}
